install.package(islr)
install.packages(islr)
install.packages("ISLR")
Library("ISLR")
library(ISLR)
force(Hitters)
colnames(Hitters)
model1 <- lm(Hitters.Salary ~ Hitters.AtBat + Hitters.Hits + Hitters.HmRun + Hitters.Runs + Hitters.RBI, data=Hitters)
model1 <- lm(Salary ~ AtBat, data=Hitters)
AIC(model1)
